generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum CompetitionTargetType {
  COUNTRY
  CLUB
}

enum CompetitionScopeType {
  GLOBAL
  CONFEDERATION
  COUNTRY
  CUSTOM
}

enum CompetitionStandingPlacement {
  CHAMPION
  RUNNER_UP
  THIRD_PLACE
  FOURTH_PLACE
  SEMI_FINALIST
}

enum CompetitionEditionStandingMode {
  THIRD_PLACE_MATCH
  SEMI_FINALISTS
  FINAL_ONLY
  LEAGUE_TOP_THREE
  DOUBLE_THIRD_PLACE
}

enum PlayerCareerType {
  CLUB
  COUNTRY
}

enum AwardScopeType {
  WORLD
  CONFEDERATION
  COUNTRY
  LEAGUE
  CLUB
  MEDIA
}

enum AwardTargetType {
  PLAYER
  COUNTRY
  CLUB
}

enum LifecycleStatus {
  CURRENT
  DISCONTINUED
}

enum PlayerTeamHonorSourceType {
  MANUAL
  CAREER_MATCH
  IMPORT
}

enum PlayerTeamHonorStatus {
  CONFIRMED
  PENDING
  EXCLUDED
}

enum AuditAction {
  CREATE
  UPDATE
  RECALCULATE
  IMPORT
  UPSERT
  OTHER
}

enum HonorRulePlacementScope {
  TOP_FOUR
  TOP_THREE
  TOP_TWO
  LEAGUE_TOP_THREE
  CHAMPION_ONLY
}

enum HonorRuleConversionType {
  NONE
  FREQUENCY_SCALE
  OLYMPIC_STAGE
  CLUB_WORLD_CUP_STAGE
}

model Player {
  id                 String              @id @default(cuid())
  importKey          String              @unique
  uid                String
  chineseName        String
  englishName        String?
  birthDate          Float?
  deathDate          Float?
  age                Int?
  primaryRole        String?
  positions          String?
  ca                 Int?
  pa                 Int?
  honorScore         Float?
  awardCount         Int?
  topAwardCount      Int?
  height             Int?
  weight             Int?
  shirtNumber        String?
  skinTone           String?
  hairColor          String?
  hairColorId        String?
  ethnicity          String?
  ethnicityId        String?
  foot               String?
  preferredFootId    String?
  playerType         String?
  playerTypeId       String?
  confederation      String?
  confederationId    String?
  countryUid         String?
  representedCountry String?
  nationality        String?
  birthCityUid       String?
  birthCity          String?
  birthCountryId     String?
  birthCityId        String?
  primaryClub        String?
  externalUrl        String?
  clubUid            String?
  initialClubId      String?
  initialClub        String?
  clubs              String?
  marketValue        Float?
  retired            Boolean?
  deceased           Boolean?
  databaseSource     String?
  staffRoles         String?
  achievement        String?
  remark             String?
  countryId          String?
  clubId             String?
  country            Country?            @relation(fields: [countryId], references: [id])
  birthCountry       Country?            @relation("PlayerBirthCountry", fields: [birthCountryId], references: [id])
  birthCityRef       City?               @relation(fields: [birthCityId], references: [id])
  club               Club?               @relation(fields: [clubId], references: [id])
  initialClubRef     Club?               @relation("PlayerInitialClub", fields: [initialClubId], references: [id])
  confederationRef   Confederation?      @relation(fields: [confederationId], references: [id])
  hairColorRef       HairColor?          @relation(fields: [hairColorId], references: [id])
  ethnicityRef       Ethnicity?          @relation(fields: [ethnicityId], references: [id])
  preferredFootRef   PreferredFoot?      @relation(fields: [preferredFootId], references: [id])
  playerTypeRef      PlayerType?         @relation(fields: [playerTypeId], references: [id])
  nationalities      PlayerNationality[]
  careers            PlayerCareer[]
  awardRecipients    AwardRecipient[]
  teamHonors         PlayerTeamHonor[]
  honors             PlayerHonor[]
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt

  @@index([countryId])
  @@index([birthCountryId])
  @@index([birthCityId])
  @@index([clubId])
  @@index([initialClubId])
  @@index([confederationId])
  @@index([hairColorId])
  @@index([ethnicityId])
  @@index([preferredFootId])
  @@index([playerTypeId])
  @@index([countryUid])
  @@index([clubUid])
  @@index([pa])
  @@index([honorScore])
}

model AuditLog {
  id         String      @id @default(cuid())
  action     AuditAction @default(OTHER)
  module     String
  method     String
  path       String
  success    Boolean
  statusCode Int?
  objectType String?
  objectId   String?
  summary    String?
  actor      String      @default("LOCAL_USER")
  ip         String?
  userAgent  String?
  metadata   Json?
  createdAt  DateTime    @default(now())

  @@index([action])
  @@index([module])
  @@index([success])
  @@index([objectType])
  @@index([objectId])
  @@index([createdAt])
}

model Country {
  id                      String                    @id @default(cuid())
  importKey               String                    @unique
  uid                     String
  uidSort                 Int?
  name                    String
  externalUrl             String?
  remark                  String?
  federation              String?
  federationId            String?
  visibleInCatalog        Boolean                   @default(true)
  isHistorical            Boolean                   @default(false)
  detailRedirectCountryId String?
  playerCount             Int?
  totalPa                 Int?
  averagePa               Float?
  medalCount              Int?
  championCount           Int?
  majorChampionCount      Int?
  baseHonorScore          Float?
  bonusHonorScore         Float?
  honorScore              Float?
  averageHonorScore       Float?
  players                 Player[]
  birthPlayers            Player[]                  @relation("PlayerBirthCountry")
  playerNationalities     PlayerNationality[]
  cities                  City[]
  clubs                   Club[]
  playerCareers           PlayerCareer[]
  federationRef           Confederation?            @relation(fields: [federationId], references: [id])
  detailRedirectCountry   Country?                  @relation("CountryDetailRedirect", fields: [detailRedirectCountryId], references: [id])
  redirectSourceCountries Country[]                 @relation("CountryDetailRedirect")
  historicalSuccessors    CountrySuccessor[]        @relation("HistoricalCountrySuccessors")
  inheritedFromCountries  CountrySuccessor[]        @relation("CountryInheritedFrom")
  honors                  CountryHonor[]
  scopedAwards            Award[]                   @relation("AwardScopeCountry")
  honorRules              HonorRule[]               @relation("HonorRuleScopeCountry")
  honorRuleCoefficients   HonorRuleCoefficient[]    @relation("HonorRuleCoefficientCountry")
  scopedCompetitions      Competition[]             @relation("CompetitionLegacyScopeCountry")
  competitionScopeLinks   CompetitionScopeCountry[]
  competitionResults      CompetitionStanding[]
  awardRecipients         AwardRecipient[]
  createdAt               DateTime                  @default(now())
  updatedAt               DateTime                  @updatedAt

  @@index([federation])
  @@index([federationId])
  @@index([uidSort])
  @@index([visibleInCatalog])
  @@index([isHistorical])
  @@index([detailRedirectCountryId])
}

model CountrySuccessor {
  historicalCountryId String
  successorCountryId  String
  historicalCountry   Country  @relation("HistoricalCountrySuccessors", fields: [historicalCountryId], references: [id], onDelete: Cascade)
  successorCountry    Country  @relation("CountryInheritedFrom", fields: [successorCountryId], references: [id], onDelete: Cascade)
  createdAt           DateTime @default(now())

  @@id([historicalCountryId, successorCountryId])
  @@index([successorCountryId])
}

model City {
  id          String   @id @default(cuid())
  importKey   String   @unique
  uid         String
  name        String
  countryId   String?
  description String?
  sortOrder   Int      @default(0)
  country     Country? @relation(fields: [countryId], references: [id])
  players     Player[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([uid])
  @@index([name])
  @@index([countryId])
}

model PlayerNationality {
  playerId  String
  countryId String
  player    Player   @relation(fields: [playerId], references: [id], onDelete: Cascade)
  country   Country  @relation(fields: [countryId], references: [id])
  createdAt DateTime @default(now())

  @@id([playerId, countryId])
  @@index([countryId])
}

model Club {
  id                 String                @id @default(cuid())
  importKey          String                @unique
  uid                String
  name               String
  formerName         String?
  alias              String?
  externalUrl        String?
  remark             String?
  exists             Boolean               @default(true)
  visibleInCatalog   Boolean               @default(true)
  countryUid         String?
  countryId          String?
  country            String?
  federation         String?
  federationId       String?
  playerCount        Int?
  totalPa            Int?
  averagePa          Float?
  trophyCount        Int?
  championCount      Int?
  baseHonorScore     Float?
  bonusHonorScore    Float?
  honorScore         Float?
  countryRef         Country?              @relation(fields: [countryId], references: [id])
  federationRef      Confederation?        @relation(fields: [federationId], references: [id])
  players            Player[]
  initialPlayers     Player[]              @relation("PlayerInitialClub")
  playerCareers      PlayerCareer[]
  honors             ClubHonor[]
  competitionResults CompetitionStanding[]
  awardRecipients    AwardRecipient[]
  createdAt          DateTime              @default(now())
  updatedAt          DateTime              @updatedAt

  @@index([countryId])
  @@index([countryUid])
  @@index([country])
  @@index([federation])
  @@index([federationId])
  @@index([visibleInCatalog])
}

model PlayerCareer {
  id               String            @id @default(cuid())
  playerId         String
  careerType       PlayerCareerType
  clubId           String?
  countryId        String?
  startYear        Int?
  endYear          Int?
  startSeason      String?
  endSeason        String?
  appearances      Int?
  goals            Int?
  assists          Int?
  cleanSheets      Int?
  goalsConceded    Int?
  position         String?
  positionGroup    String?
  showInProfile    Boolean           @default(true)
  isRepresentative Boolean           @default(false)
  isLegend         Boolean           @default(false)
  sortOrder        Int               @default(0)
  remark           String?
  player           Player            @relation(fields: [playerId], references: [id], onDelete: Cascade)
  club             Club?             @relation(fields: [clubId], references: [id])
  country          Country?          @relation(fields: [countryId], references: [id])
  teamHonors       PlayerTeamHonor[]
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt

  @@index([playerId])
  @@index([careerType])
  @@index([clubId])
  @@index([countryId])
  @@index([showInProfile])
  @@index([isRepresentative])
  @@index([isLegend])
}

model PlayerTeamHonor {
  id         String                    @id @default(cuid())
  playerId   String
  standingId String
  careerId   String?
  sourceType PlayerTeamHonorSourceType @default(MANUAL)
  status     PlayerTeamHonorStatus     @default(CONFIRMED)
  remark     String?
  player     Player                    @relation(fields: [playerId], references: [id], onDelete: Cascade)
  standing   CompetitionStanding       @relation(fields: [standingId], references: [id], onDelete: Cascade)
  career     PlayerCareer?             @relation(fields: [careerId], references: [id], onDelete: SetNull)
  createdAt  DateTime                  @default(now())
  updatedAt  DateTime                  @updatedAt

  @@unique([playerId, standingId])
  @@index([playerId])
  @@index([standingId])
  @@index([careerId])
  @@index([sourceType])
  @@index([status])
}

model HonorRule {
  id                  String                       @id @default(cuid())
  code                String                       @unique
  name                String
  targetType          CompetitionTargetType        @default(COUNTRY)
  category            String?
  level               String?
  format              String?
  scopeType           CompetitionScopeType?
  confederationId     String?
  countryId           String?
  placement           CompetitionStandingPlacement @default(CHAMPION)
  placementScope      HonorRulePlacementScope      @default(TOP_TWO)
  conversionType      HonorRuleConversionType      @default(NONE)
  baseScore           Float                        @default(0)
  championScore       Float?
  runnerUpScore       Float?
  thirdPlaceScore     Float?
  fourthPlaceScore    Float?
  semiFinalistScore   Float?
  coefficient         Float                        @default(1)
  qualityCoefficient  Float                        @default(1)
  isSystem            Boolean                      @default(false)
  enabled             Boolean                      @default(true)
  sortOrder           Int                          @default(0)
  remark              String?
  confederation       Confederation?               @relation("HonorRuleScopeConfederation", fields: [confederationId], references: [id])
  country             Country?                     @relation("HonorRuleScopeCountry", fields: [countryId], references: [id])
  typicalCompetitions HonorRuleCompetition[]
  coefficients        HonorRuleCoefficient[]
  createdAt           DateTime                     @default(now())
  updatedAt           DateTime                     @updatedAt

  @@index([targetType])
  @@index([category])
  @@index([level])
  @@index([format])
  @@index([scopeType])
  @@index([confederationId])
  @@index([countryId])
  @@index([placement])
  @@index([placementScope])
  @@index([conversionType])
  @@index([isSystem])
  @@index([enabled])
}

model HonorRuleCompetition {
  honorRuleId   String
  competitionId String
  honorRule     HonorRule   @relation(fields: [honorRuleId], references: [id], onDelete: Cascade)
  competition   Competition @relation(fields: [competitionId], references: [id], onDelete: Cascade)
  createdAt     DateTime    @default(now())

  @@id([honorRuleId, competitionId])
  @@index([competitionId])
}

model HonorRuleCoefficient {
  id              String         @id @default(cuid())
  honorRuleId     String
  confederationId String?
  countryId       String?
  coefficient     Float          @default(1)
  honorRule       HonorRule      @relation(fields: [honorRuleId], references: [id], onDelete: Cascade)
  confederation   Confederation? @relation("HonorRuleCoefficientConfederation", fields: [confederationId], references: [id])
  country         Country?       @relation("HonorRuleCoefficientCountry", fields: [countryId], references: [id])
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  @@index([honorRuleId])
  @@index([confederationId])
  @@index([countryId])
}

model AwardRule {
  id          String          @id @default(cuid())
  code        String          @unique
  name        String
  scopeType   AwardScopeType?
  category    String?
  placement   String?
  rank        Int?
  baseScore   Float           @default(0)
  coefficient Float           @default(1)
  topAward    Boolean         @default(false)
  enabled     Boolean         @default(true)
  sortOrder   Int             @default(0)
  remark      String?
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  @@index([scopeType])
  @@index([category])
  @@index([placement])
  @@index([rank])
  @@index([enabled])
}

model TeamHonorRule {
  id          String          @id @default(cuid())
  code        String          @unique
  name        String
  targetType  AwardTargetType
  scopeType   AwardScopeType?
  category    String?
  placement   String?
  rank        Int?
  baseScore   Float           @default(0)
  coefficient Float           @default(1)
  enabled     Boolean         @default(true)
  sortOrder   Int             @default(0)
  remark      String?
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  @@index([targetType])
  @@index([scopeType])
  @@index([category])
  @@index([placement])
  @@index([rank])
  @@index([enabled])
}

model PlayerHonor {
  id       String  @id @default(cuid())
  playerId String
  player   Player  @relation(fields: [playerId], references: [id])
  name     String
  score    Float   @default(0)
  season   String?
}

model CountryHonor {
  id        String  @id @default(cuid())
  countryId String
  country   Country @relation(fields: [countryId], references: [id])
  name      String
  score     Float   @default(0)
  season    String?
}

model ClubHonor {
  id     String  @id @default(cuid())
  clubId String
  club   Club    @relation(fields: [clubId], references: [id])
  name   String
  score  Float   @default(0)
  season String?
}

model Position {
  id          String   @id @default(cuid())
  code        String   @unique
  name        String
  group       String?
  description String?
  enabled     Boolean  @default(true)
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model PlayerType {
  id          String   @id @default(cuid())
  code        String   @unique
  name        String
  description String?
  enabled     Boolean  @default(true)
  sortOrder   Int      @default(0)
  players     Player[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Confederation {
  id                    String                          @id @default(cuid())
  uid                   String                          @unique
  name                  String
  code                  String?
  sortOrder             Int                             @default(0)
  scopedAwards          Award[]                         @relation("AwardScopeConfederation")
  honorRules            HonorRule[]                     @relation("HonorRuleScopeConfederation")
  honorRuleCoefficients HonorRuleCoefficient[]          @relation("HonorRuleCoefficientConfederation")
  countries             Country[]
  clubs                 Club[]
  players               Player[]
  scopedCompetitions    Competition[]                   @relation("CompetitionLegacyScopeConfederation")
  competitionScopeLinks CompetitionScopeConfederation[]
  createdAt             DateTime                        @default(now())
  updatedAt             DateTime                        @updatedAt
}

model Competition {
  id                  String                          @id @default(cuid())
  code                String                          @unique
  name                String
  alias               String?
  externalUrl         String?
  targetType          CompetitionTargetType
  scopeType           CompetitionScopeType            @default(GLOBAL)
  category            String?
  level               String?
  format              String?
  description         String?
  confederationId     String?
  countryId           String?
  lifecycleStatus     LifecycleStatus                 @default(CURRENT)
  enabled             Boolean                         @default(true)
  includeInStats      Boolean                         @default(true)
  sortOrder           Int                             @default(0)
  confederation       Confederation?                  @relation("CompetitionLegacyScopeConfederation", fields: [confederationId], references: [id])
  country             Country?                        @relation("CompetitionLegacyScopeCountry", fields: [countryId], references: [id])
  scopeConfederations CompetitionScopeConfederation[]
  scopeCountries      CompetitionScopeCountry[]
  typicalHonorRules   HonorRuleCompetition[]
  editions            CompetitionEdition[]
  createdAt           DateTime                        @default(now())
  updatedAt           DateTime                        @updatedAt

  @@index([targetType])
  @@index([alias])
  @@index([scopeType])
  @@index([category])
  @@index([level])
  @@index([format])
  @@index([confederationId])
  @@index([countryId])
  @@index([lifecycleStatus])
  @@index([enabled])
  @@index([includeInStats])
}

model CompetitionScopeConfederation {
  competitionId   String
  confederationId String
  competition     Competition   @relation(fields: [competitionId], references: [id], onDelete: Cascade)
  confederation   Confederation @relation(fields: [confederationId], references: [id], onDelete: Cascade)
  createdAt       DateTime      @default(now())

  @@id([competitionId, confederationId])
  @@index([confederationId])
}

model CompetitionScopeCountry {
  competitionId String
  countryId     String
  competition   Competition @relation(fields: [competitionId], references: [id], onDelete: Cascade)
  country       Country     @relation(fields: [countryId], references: [id], onDelete: Cascade)
  createdAt     DateTime    @default(now())

  @@id([competitionId, countryId])
  @@index([countryId])
}

model Award {
  id              String          @id @default(cuid())
  code            String          @unique
  name            String
  externalUrl     String?
  targetType      AwardTargetType @default(PLAYER)
  scopeType       AwardScopeType  @default(WORLD)
  category        String?
  level           String?
  description     String?
  confederationId String?
  countryId       String?
  lifecycleStatus LifecycleStatus @default(CURRENT)
  enabled         Boolean         @default(true)
  sortOrder       Int             @default(0)
  confederation   Confederation?  @relation("AwardScopeConfederation", fields: [confederationId], references: [id])
  country         Country?        @relation("AwardScopeCountry", fields: [countryId], references: [id])
  editions        AwardEdition[]
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  @@index([targetType])
  @@index([scopeType])
  @@index([category])
  @@index([confederationId])
  @@index([countryId])
  @@index([lifecycleStatus])
  @@index([enabled])
}

model AwardEdition {
  id          String           @id @default(cuid())
  awardId     String
  name        String
  season      String?
  year        Int?
  externalUrl String?
  remark      String?
  award       Award            @relation(fields: [awardId], references: [id], onDelete: Cascade)
  recipients  AwardRecipient[]
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  @@unique([awardId, name])
  @@index([awardId])
  @@index([year])
}

model AwardRecipient {
  id          String          @id @default(cuid())
  editionId   String
  targetType  AwardTargetType @default(PLAYER)
  playerId    String?
  countryId   String?
  clubId      String?
  rank        Int?
  placement   String?
  externalUrl String?
  remark      String?
  edition     AwardEdition    @relation(fields: [editionId], references: [id], onDelete: Cascade)
  player      Player?         @relation(fields: [playerId], references: [id])
  country     Country?        @relation(fields: [countryId], references: [id])
  club        Club?           @relation(fields: [clubId], references: [id])
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  @@unique([editionId, targetType, playerId])
  @@unique([editionId, targetType, countryId])
  @@unique([editionId, targetType, clubId])
  @@index([targetType])
  @@index([playerId])
  @@index([countryId])
  @@index([clubId])
  @@index([rank])
  @@index([placement])
}

model CompetitionEdition {
  id            String                         @id @default(cuid())
  competitionId String
  name          String
  season        String?
  year          Int?
  quantity      Int?
  standingMode  CompetitionEditionStandingMode @default(THIRD_PLACE_MATCH)
  host          String?
  externalUrl   String?
  remark        String?
  competition   Competition                    @relation(fields: [competitionId], references: [id], onDelete: Cascade)
  standings     CompetitionStanding[]
  createdAt     DateTime                       @default(now())
  updatedAt     DateTime                       @updatedAt

  @@unique([competitionId, name])
  @@index([competitionId])
  @@index([year])
}

model CompetitionStanding {
  id               String                       @id @default(cuid())
  editionId        String
  placement        CompetitionStandingPlacement
  standingOrder    Int                          @default(0)
  countryId        String?
  clubId           String?
  remark           String?
  edition          CompetitionEdition           @relation(fields: [editionId], references: [id], onDelete: Cascade)
  country          Country?                     @relation(fields: [countryId], references: [id])
  club             Club?                        @relation(fields: [clubId], references: [id])
  playerTeamHonors PlayerTeamHonor[]
  createdAt        DateTime                     @default(now())
  updatedAt        DateTime                     @updatedAt

  @@index([editionId, placement])
  @@index([countryId])
  @@index([clubId])
  @@index([placement])
}

model PotentialRange {
  id          String   @id @default(cuid())
  code        String   @unique
  name        String?
  description String?
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Ethnicity {
  id          String   @id @default(cuid())
  code        String   @unique
  name        String
  description String?
  sortOrder   Int      @default(0)
  players     Player[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model HairColor {
  id          String   @id @default(cuid())
  code        String   @unique
  name        String
  description String?
  sortOrder   Int      @default(0)
  players     Player[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model PreferredFoot {
  id          String   @id @default(cuid())
  code        String   @unique
  name        String
  description String?
  sortOrder   Int      @default(0)
  players     Player[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model ImportTask {
  id             String    @id @default(cuid())
  fileName       String
  fileType       String
  sourceType     String    @default("lakesheet")
  status         String    @default("pending")
  totalRows      Int       @default(0)
  successRows    Int       @default(0)
  failedRows     Int       @default(0)
  errorReportUrl String?
  createdBy      String?
  previewData    Json?
  startedAt      DateTime?
  finishedAt     DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  @@index([status])
  @@index([sourceType])
  @@index([createdAt])
}
