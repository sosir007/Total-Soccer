generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum CompetitionTargetType {
  COUNTRY
  CLUB
}

enum CompetitionScopeType {
  GLOBAL
  CONFEDERATION
  COUNTRY
  CUSTOM
}

enum CompetitionStandingPlacement {
  CHAMPION
  RUNNER_UP
  THIRD_PLACE
  FOURTH_PLACE
}

model Player {
  id                 String         @id @default(cuid())
  importKey          String         @unique
  uid                String
  chineseName        String
  englishName        String?
  birthDate          DateTime?
  deathDate          DateTime?
  age                Int?
  primaryRole        String?
  positions          String?
  ca                 Int?
  pa                 Int?
  height             Int?
  weight             Int?
  shirtNumber        String?
  skinTone           String?
  hairColor          String?
  hairColorId        String?
  ethnicity          String?
  ethnicityId        String?
  foot               String?
  preferredFootId    String?
  playerType         String?
  playerTypeId       String?
  confederation      String?
  confederationId    String?
  countryUid         String?
  representedCountry String?
  nationality        String?
  birthCityUid       String?
  birthCity          String?
  primaryClub        String?
  clubUid            String?
  initialClub        String?
  clubs              String?
  marketValue        Float?
  retired            Boolean?
  deceased           Boolean?
  databaseSource     String?
  staffRoles         String?
  achievement        String?
  remark             String?
  countryId          String?
  clubId             String?
  country            Country?       @relation(fields: [countryId], references: [id])
  club               Club?          @relation(fields: [clubId], references: [id])
  confederationRef   Confederation? @relation(fields: [confederationId], references: [id])
  hairColorRef       HairColor?     @relation(fields: [hairColorId], references: [id])
  ethnicityRef       Ethnicity?     @relation(fields: [ethnicityId], references: [id])
  preferredFootRef   PreferredFoot? @relation(fields: [preferredFootId], references: [id])
  playerTypeRef      PlayerType?    @relation(fields: [playerTypeId], references: [id])
  honors             PlayerHonor[]
  createdAt          DateTime       @default(now())
  updatedAt          DateTime       @updatedAt

  @@index([countryId])
  @@index([clubId])
  @@index([confederationId])
  @@index([hairColorId])
  @@index([ethnicityId])
  @@index([preferredFootId])
  @@index([playerTypeId])
  @@index([countryUid])
  @@index([clubUid])
  @@index([pa])
}

model Country {
  id                 String         @id @default(cuid())
  importKey          String         @unique
  uid                String
  name               String
  federation         String?
  federationId       String?
  playerCount        Int?
  totalPa            Int?
  averagePa          Float?
  medalCount         Int?
  championCount      Int?
  majorChampionCount Int?
  honorScore         Float?
  averageHonorScore  Float?
  players            Player[]
  clubs              Club[]
  federationRef      Confederation? @relation(fields: [federationId], references: [id])
  honors             CountryHonor[]
  scopedCompetitions Competition[]  @relation("CompetitionScopeCountry")
  competitionResults CompetitionStanding[]
  createdAt          DateTime       @default(now())
  updatedAt          DateTime       @updatedAt

  @@index([federation])
  @@index([federationId])
}

model Club {
  id            String         @id @default(cuid())
  importKey     String         @unique
  uid           String
  name          String
  exists        Boolean        @default(true)
  countryUid    String?
  countryId     String?
  country       String?
  federation    String?
  federationId  String?
  playerCount   Int?
  totalPa       Int?
  averagePa     Float?
  trophyCount   Int?
  championCount Int?
  honorScore    Float?
  countryRef    Country?       @relation(fields: [countryId], references: [id])
  federationRef Confederation? @relation(fields: [federationId], references: [id])
  players       Player[]
  honors        ClubHonor[]
  competitionResults CompetitionStanding[]
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  @@index([countryId])
  @@index([countryUid])
  @@index([country])
  @@index([federation])
  @@index([federationId])
}

model HonorRule {
  id              String   @id @default(cuid())
  code            String   @unique
  name            String
  category        String
  championScore   Float?
  runnerUpScore   Float?
  thirdPlaceScore Float?
  coefficient     Float    @default(1)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model PlayerHonor {
  id       String  @id @default(cuid())
  playerId String
  player   Player  @relation(fields: [playerId], references: [id])
  name     String
  score    Float   @default(0)
  season   String?
}

model CountryHonor {
  id        String  @id @default(cuid())
  countryId String
  country   Country @relation(fields: [countryId], references: [id])
  name      String
  score     Float   @default(0)
  season    String?
}

model ClubHonor {
  id     String  @id @default(cuid())
  clubId String
  club   Club    @relation(fields: [clubId], references: [id])
  name   String
  score  Float   @default(0)
  season String?
}

model Position {
  id          String   @id @default(cuid())
  code        String   @unique
  name        String
  group       String?
  description String?
  enabled     Boolean  @default(true)
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model PlayerType {
  id          String   @id @default(cuid())
  code        String   @unique
  name        String
  description String?
  enabled     Boolean  @default(true)
  sortOrder   Int      @default(0)
  players     Player[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Confederation {
  id        String    @id @default(cuid())
  uid       String    @unique
  name      String
  code      String?
  sortOrder Int       @default(0)
  countries Country[]
  clubs     Club[]
  players   Player[]
  scopedCompetitions Competition[] @relation("CompetitionScopeConfederation")
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
}

model Competition {
  id              String                @id @default(cuid())
  code            String                @unique
  name            String
  targetType      CompetitionTargetType
  scopeType       CompetitionScopeType  @default(GLOBAL)
  category        String?
  level           String?
  confederationId String?
  countryId       String?
  enabled         Boolean               @default(true)
  sortOrder       Int                   @default(0)
  confederation   Confederation?        @relation("CompetitionScopeConfederation", fields: [confederationId], references: [id])
  country         Country?              @relation("CompetitionScopeCountry", fields: [countryId], references: [id])
  editions        CompetitionEdition[]
  createdAt       DateTime              @default(now())
  updatedAt       DateTime              @updatedAt

  @@index([targetType])
  @@index([scopeType])
  @@index([confederationId])
  @@index([countryId])
  @@index([enabled])
}

model CompetitionEdition {
  id            String                @id @default(cuid())
  competitionId String
  name          String
  season        String?
  year          Int?
  host          String?
  remark        String?
  competition   Competition           @relation(fields: [competitionId], references: [id], onDelete: Cascade)
  standings     CompetitionStanding[]
  createdAt     DateTime              @default(now())
  updatedAt     DateTime              @updatedAt

  @@unique([competitionId, name])
  @@index([competitionId])
  @@index([year])
}

model CompetitionStanding {
  id        String                       @id @default(cuid())
  editionId String
  placement CompetitionStandingPlacement
  countryId String?
  clubId    String?
  remark    String?
  edition   CompetitionEdition           @relation(fields: [editionId], references: [id], onDelete: Cascade)
  country   Country?                     @relation(fields: [countryId], references: [id])
  club      Club?                        @relation(fields: [clubId], references: [id])
  createdAt DateTime                     @default(now())
  updatedAt DateTime                     @updatedAt

  @@unique([editionId, placement])
  @@index([countryId])
  @@index([clubId])
  @@index([placement])
}

model PotentialRange {
  id          String   @id @default(cuid())
  code        String   @unique
  name        String?
  description String?
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Ethnicity {
  id          String   @id @default(cuid())
  code        String   @unique
  name        String
  description String?
  sortOrder   Int      @default(0)
  players     Player[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model HairColor {
  id          String   @id @default(cuid())
  code        String   @unique
  name        String
  description String?
  sortOrder   Int      @default(0)
  players     Player[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model PreferredFoot {
  id          String   @id @default(cuid())
  code        String   @unique
  name        String
  description String?
  sortOrder   Int      @default(0)
  players     Player[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model ImportTask {
  id             String    @id @default(cuid())
  fileName       String
  fileType       String
  sourceType     String    @default("lakesheet")
  status         String    @default("pending")
  totalRows      Int       @default(0)
  successRows    Int       @default(0)
  failedRows     Int       @default(0)
  errorReportUrl String?
  createdBy      String?
  previewData    Json?
  startedAt      DateTime?
  finishedAt     DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  @@index([status])
  @@index([sourceType])
  @@index([createdAt])
}
