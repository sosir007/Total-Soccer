{
  "name": "total-soccer",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "A football data platform for players, clubs, nations, honors, ratings, and historical statistics.",
  "packageManager": "pnpm@9.15.0",
  "scripts": {
    "dev": "pnpm -r --parallel dev",
    "dev:web": "pnpm --filter @total-soccer/web dev",
    "dev:api": "pnpm --filter @total-soccer/api dev",
    "build": "pnpm -r build",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "type-check": "pnpm -r type-check"
  },
  "engines": {
    "node": ">=20.11.0",
    "pnpm": ">=9.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.17.0",
    "@types/node": "^22.10.2",
    "eslint": "^9.17.0",
    "eslint-plugin-vue": "^9.32.0",
    "globals": "^15.14.0",
    "prettier": "^3.4.2",
    "typescript-eslint": "^8.18.2",
    "vue-eslint-parser": "^9.4.3"
  }
}
