{
  "name": "total-soccer",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "A football data platform for players, clubs, nations, honors, ratings, and historical statistics.",
  "packageManager": "pnpm@9.15.0",
  "scripts": {
    "dev": "pnpm -r --parallel dev",
    "dev:web": "pnpm --filter @total-soccer/web dev",
    "dev:api": "pnpm --filter @total-soccer/api dev",
    "build": "pnpm -r build",
    "lint": "pnpm lint:eslint && pnpm lint:style",
    "lint:eslint": "eslint .",
    "lint:style": "stylelint \"apps/**/*.{css,vue}\"",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "type-check": "pnpm -r type-check",
    "prepare": "husky",
    "commit": "cz"
  },
  "engines": {
    "node": ">=20.11.0",
    "pnpm": ">=9.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.17.0",
    "@types/node": "^22.10.2",
    "eslint": "^9.17.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-prettier": "^5.2.1",
    "eslint-plugin-vue": "^9.32.0",
    "globals": "^15.14.0",
    "husky": "^9.1.7",
    "lint-staged": "^15.2.11",
    "@commitlint/cli": "^19.6.1",
    "@commitlint/config-conventional": "^19.6.0",
    "commitizen": "^4.3.1",
    "cz-git": "^1.11.0",
    "prettier": "^3.4.2",
    "stylelint": "^17.0.0",
    "stylelint-config-html": "^1.1.0",
    "stylelint-config-recess-order": "^7.7.0",
    "stylelint-config-recommended-vue": "^1.6.0",
    "stylelint-config-standard": "^40.0.0",
    "stylelint-order": "^7.0.0",
    "typescript-eslint": "^8.18.2",
    "vue-eslint-parser": "^9.4.3"
  },
  "lint-staged": {
    "*.{js,ts,vue}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{css,vue}": [
      "stylelint --fix"
    ],
    "*.{json,md,yml,yaml}": [
      "prettier --write"
    ]
  },
  "config": {
    "commitizen": {
      "path": "node_modules/cz-git"
    }
  }
}
